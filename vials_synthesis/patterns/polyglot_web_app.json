{
  "id": "polyglot_web_app",
  "concept": "Polyglot Web app assembler: binds an app's target_language to whichever library vial implements it, and concatenates the language banner and the C++/Rust/Go/Python/JS/Assembly web server code block.",
  "rules": [
    {
      "name": "bind-web-language-library",
      "premises": [
        ["?app", "is_a", "application"],
        ["?app", "target_language", "?lang"],
        ["?lib", "implements_language", "?lang"]
      ],
      "conclusion": ["?app", "uses_web_language", "?lib"]
    },
    {
      "name": "assemble-polyglot-web-app",
      "premises": [
        ["?app", "is_a", "application"],
        ["?app", "needs", "web_server"],
        ["?app", "uses_web_language", "?lib"],
        ["?lib", "code_banner", "?banner"],
        ["?lib", "code_web_body", "?body"]
      ],
      "conclusion": ["?app", "code", "?code"],
      "compute": "?code = ?banner + ?body"
    }
  ],
  "evidence": ["Language-agnostic Web program assembly: capability/provider binding over target_language"]
}
