{
  "id": "polyglot_db_app",
  "concept": "Polyglot Database app assembler: binds an app's target_language to whichever library vial implements it, and concatenates the language banner and the database-backed code block.",
  "rules": [
    {
      "name": "bind-db-language-library",
      "premises": [
        ["?app", "is_a", "application"],
        ["?app", "target_language", "?lang"],
        ["?lib", "implements_language", "?lang"]
      ],
      "conclusion": ["?app", "uses_db_language", "?lib"]
    },
    {
      "name": "assemble-polyglot-db-app",
      "premises": [
        ["?app", "is_a", "application"],
        ["?app", "needs", "db_connector"],
        ["?app", "uses_db_language", "?lib"],
        ["?lib", "code_banner", "?banner"],
        ["?lib", "code_db_body", "?body"]
      ],
      "conclusion": ["?app", "code", "?code"],
      "compute": "?code = ?banner + ?body"
    }
  ],
  "evidence": ["Language-agnostic database application assembly: capability/provider binding over target_language"]
}
